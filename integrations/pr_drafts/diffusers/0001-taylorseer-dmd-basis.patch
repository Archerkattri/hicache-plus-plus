+    def _predict_dmd(self, output_index: int) -> torch.Tensor | None:
+        r"""
+        Dynamic Mode Decomposition (Prony) forecast for one output stream, or `None` to fall back to Taylor.
+
+        Only the longest *uniformly spaced* suffix of the snapshot history is used — the identified propagator
+        advances exactly one snapshot-spacing per application, so a mixed-spacing window (e.g. across the warmup
+        boundary) would corrupt the fit. The skip horizon is fractional in snapshot-spacing units. The window floor
+        is 4 snapshots: a real-valued trajectory spends two real degrees of freedom per complex pole, so even one
+        oscillatory mode needs three snapshot pairs to identify.
+        """
+        stream = self.snapshots.get(output_index, [])
+        if len(stream) < 4:
+            return None
+        steps = [step for step, _ in stream]
+        spacing = steps[-1] - steps[-2]
+        if spacing <= 0:
+            return None
+        tail = [stream[-1], stream[-2]]
+        j = len(stream) - 2
+        while j - 1 >= 0 and steps[j] - steps[j - 1] == spacing:
+            tail.append(stream[j - 1])
+            j -= 1
+        if len(tail) < 4:
+            return None
+        velocities = [snapshot for _, snapshot in reversed(tail)]
+        horizon = (self.current_step - steps[-1]) / spacing
+        return _dmd_forecast(velocities, horizon, rank=self.dmd_rank, ridge=self.dmd_ridge)
+
 
